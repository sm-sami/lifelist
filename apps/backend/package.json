{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.local --watch --import=tsx/esm src/server.ts",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx --env-file=.env.local db/migrate.ts",
    "db:backfill-semantics": "tsx --env-file=.env.local db/backfill-item-semantics.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "@lifelist/shared": "workspace:*",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/functions": "^3.7.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "openai": "^6.44.0",
    "postgres": "^3.4.9",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "vitest": "2.1.9"
  }
}
