# These values are embedded in the Expo client and are therefore PUBLIC.
# Never add the Supabase secret key, database, OpenAI, or Unsplash secrets here.

EXPO_PUBLIC_SUPABASE_URL="https://<PROJECT_REF>.supabase.co"
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<PUBLISHABLE_KEY>"

# Choose one URL for the runtime:
# iOS Simulator:    http://127.0.0.1:3000/api
# Android Emulator: http://10.0.2.2:3000/api
# Physical device:  http://<YOUR_LAN_IP>:3000/api
EXPO_PUBLIC_API_BASE_URL="http://127.0.0.1:3000/api"
